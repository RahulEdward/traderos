generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ───────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  image               String?
  hashedPassword      String?
  emailVerified       DateTime?
  tier                String    @default("FREE")
  timezone            String    @default("Asia/Kolkata")
  currency            String    @default("INR")
  riskProfile         String?
  onboardingCompleted Boolean   @default(false)
  tradingPlatform     String?
  marketFocus         String    @default("[]")
  notificationPrefs   String?
  payuCustomerId      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  strategies         Strategy[]
  portfolios         Portfolio[]
  tasks              Task[]
  liveTrades         LiveTrade[]
  webhooks           Webhook[]
  notifications      Notification[]
  integrationSettings IntegrationSetting[]
  subscriptions      Subscription[]
  watchlist          Watchlist[]
  downloadJobs       DataDownloadJob[]
  backtestRuns       BacktestRun[]

  @@map("users")
}

model Strategy {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  market      String?
  instrument  String?
  timeframe   String?
  entryLogic  String?
  exitLogic   String?
  status      String   @default("IDEA")
  tags        String   @default("[]")
  version     Int      @default(1)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  backtestResults   BacktestResult[]
  aiAnalyses        AiAnalysis[]
  tasks             Task[]
  liveTrades        LiveTrade[]
  webhooks          Webhook[]
  notifications     Notification[]
  portfolioStrategies PortfolioStrategy[]
  backtestRuns      BacktestRun[]

  @@map("strategies")
}

model BacktestResult {
  id              String   @id @default(cuid())
  strategyId      String
  versionNumber   Int
  importedAt      DateTime @default(now())
  sourcePlatform  String   @default("CUSTOM")
  rawFileUrl      String?
  totalTrades     Int      @default(0)
  winRate         Float    @default(0)
  profitFactor    Float    @default(0)
  netProfit       Float    @default(0)
  maxDrawdown     Float    @default(0)
  maxDrawdownPct  Float    @default(0)
  sharpeRatio     Float    @default(0)
  sortinoRatio    Float    @default(0)
  calmarRatio     Float    @default(0)
  expectancy      Float    @default(0)
  avgWin          Float    @default(0)
  avgLoss         Float    @default(0)
  bestTrade       Float    @default(0)
  worstTrade      Float    @default(0)
  recoveryFactor  Float    @default(0)
  psr             Float?
  dsr             Float?
  hhiPositive     Float?
  hhiNegative     Float?
  hhiTime         Float?
  drawdown95      Float?
  tuw95           Float?
  strategyRisk    Float?
  impliedPrecision Float?
  frequencyOfBets Float?
  ratioOfLongs    Float?
  startDate       DateTime?
  endDate         DateTime?
  notes           String?

  strategy   Strategy     @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  trades     Trade[]
  aiAnalyses AiAnalysis[]

  @@map("backtest_results")
}

model Trade {
  id               String   @id @default(cuid())
  backtestResultId String
  tradeNumber      Int
  entryDate        DateTime
  exitDate         DateTime?
  direction        String   @default("LONG")
  entryPrice       Float
  exitPrice        Float?
  profitLoss       Float    @default(0)
  profitLossPct    Float    @default(0)
  holdingPeriod    Int      @default(0)
  symbol           String?

  backtestResult BacktestResult @relation(fields: [backtestResultId], references: [id], onDelete: Cascade)

  @@map("trades")
}

model AiAnalysis {
  id                String   @id @default(cuid())
  strategyId        String
  backtestResultId  String?
  createdAt         DateTime @default(now())
  overallScore      Int      @default(0)
  readinessScore    Int      @default(0)
  readinessVerdict  String   @default("NOT_READY")
  summary           String?
  strengths         String   @default("[]")
  weaknesses        String   @default("[]")
  suggestions       String   @default("[]")
  riskNotes         String?
  marketRegimeNotes String?
  rawResponse       String?

  strategy       Strategy        @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  backtestResult BacktestResult? @relation(fields: [backtestResultId], references: [id], onDelete: SetNull)

  @@map("ai_analyses")
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioStrategies PortfolioStrategy[]
  notifications       Notification[]

  @@map("portfolios")
}

model PortfolioStrategy {
  id                   String   @id @default(cuid())
  portfolioId          String
  strategyId           String
  capitalAllocationPct Float    @default(0)
  addedAt              DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  strategy  Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, strategyId])
  @@map("portfolio_strategies")
}

model Task {
  id          String    @id @default(cuid())
  strategyId  String?
  userId      String
  title       String
  description String?
  taskType    String    @default("RESEARCH")
  priority    String    @default("MEDIUM")
  status      String    @default("TODO")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  strategy Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model LiveTrade {
  id            String    @id @default(cuid())
  strategyId    String
  userId        String
  entryDate     DateTime
  exitDate      DateTime?
  symbol        String
  direction     String    @default("LONG")
  entryPrice    Float
  exitPrice     Float?
  quantity      Int       @default(0)
  grossPnl      Float     @default(0)
  netPnl        Float     @default(0)
  broker        String?
  notes         String?
  screenshotUrl String?
  createdAt     DateTime  @default(now())

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("live_trades")
}

model Webhook {
  id              String    @id @default(cuid())
  userId          String
  strategyId      String?
  webhookKey      String    @unique
  name            String?
  createdAt       DateTime  @default(now())
  lastTriggeredAt DateTime?
  totalTriggers   Int       @default(0)

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy?    @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  logs     WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id           String   @id @default(cuid())
  webhookId    String
  receivedAt   DateTime @default(now())
  payload      String?
  status       String   @default("SUCCESS")
  errorMessage String?
  responseTime Int?

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  strategyId  String?
  portfolioId String?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy  Strategy?  @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  portfolio Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model IntegrationSetting {
  id              String   @id @default(cuid())
  userId          String
  platform        String
  apiKeyEncrypted String?
  status          String   @default("DISCONNECTED")
  lastSyncAt      DateTime?
  configJson      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("integration_settings")
}

model Subscription {
  id                      String    @id @default(cuid())
  userId                  String
  plan                    String    @default("FREE")
  payuTransactionId       String?
  payuPaymentId           String?
  status                  String    @default("ACTIVE")
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  createdAt               DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Historical Data Models ────────────────────────────────────────

model Watchlist {
  id             String   @id @default(cuid())
  userId         String
  symbol         String
  exchange       String
  instrumentType String?
  expiry         String?
  strike         Float?
  lotSize        Int?
  tickSize       Float?
  brokerSymbol   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
  @@index([symbol])
  @@index([exchange])
  @@map("watchlist")
}

model HistoricalCandle {
  id        String   @id @default(cuid())
  symbol    String
  exchange  String
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float    @default(0)
  oi        Float?
  interval  String   @default("DAILY")

  @@unique([symbol, exchange, timestamp, interval])
  @@index([symbol, exchange, interval])
  @@index([timestamp])
  @@map("historical_candles")
}

model DataDownloadJob {
  id               String    @id @default(cuid())
  userId           String
  status           String    @default("PENDING")
  totalSymbols     Int       @default(0)
  completedSymbols Int       @default(0)
  failedSymbols    Int       @default(0)
  interval         String    @default("DAILY")
  fromDate         DateTime?
  toDate           DateTime?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items DataDownloadItem[]

  @@map("data_download_jobs")
}

model DataDownloadItem {
  id        String @id @default(cuid())
  jobId     String
  symbol    String
  exchange  String
  status    String @default("PENDING")
  rowCount  Int    @default(0)
  error     String?

  job DataDownloadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("data_download_items")
}

// ─── Backtest Run Models (AFML-based) ───────────────────────────────

model BacktestRun {
  id              String   @id @default(cuid())
  strategyId      String
  userId          String
  method          String   @default("WALK_FORWARD")
  config          String?
  status          String   @default("PENDING")

  totalBets       Int?
  frequencyOfBets Float?
  avgHoldingPeriod Float?
  ratioOfLongs    Float?
  pnl             Float?
  hitRatio        Float?
  hhiPositive     Float?
  hhiNegative     Float?
  hhiTime         Float?
  maxDrawdown     Float?
  maxDrawdownPct  Float?
  drawdown95      Float?
  tuw95           Float?

  sharpeRatio     Float?
  annualizedSharpe Float?
  psr             Float?
  dsr             Float?
  sortinoRatio    Float?
  calmarRatio     Float?

  strategyRisk    Float?
  impliedPrecision Float?

  profitFactor    Float?
  expectancy      Float?
  recoveryFactor  Float?

  numPaths        Int?
  sharpeDistribution String?  @default("[]")
  numTrials       Int?

  createdAt       DateTime @default(now())
  completedAt     DateTime?

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("backtest_runs")
}
